{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xcompute",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "url": "full",
    "examples": {
      "autogenerate": false
    },
    "mdx": {
      "server": "https://xcompute.us",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navbar": {
    "links": [
        {
          "label": "控制台",
          "href": "https://xcompute.us/dashboard/overview"
        },
        {
          "label": "模型定价",
          "href": "https://xcompute.us/pricing"
        }
    ],
    "primary": {
      "type": "button",
      "label": "获取 API Key",
      "href": "https://xcompute.us/keys"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "控制台",
          "icon": "house",
          "href": "https://xcompute.us/dashboard/overview"
