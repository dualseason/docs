{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Xcompute",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "url": "full",
    "examples": {
      "autogenerate": false
    },
    "mdx": {
      "server": "https://xcompute.us",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navbar": {
    "links": [
        {
          "label": "控制台",
          "href": "https://xcompute.us/console"
        },
        {
          "label": "模型定价",
          "href": "https://xcompute.us/pricing"
        }
    ],
    "primary": {
      "type": "button",
      "label": "获取 API Key",
      "href": "https://xcompute.us/console/token"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "控制台",
          "icon": "house",
          "href": "https://xcompute.us/console"
        },
        {
          "anchor": "API 密钥",
          "icon": "key",
          "href": "https://xcompute.us/console/token"
        },
        {
          "anchor": "模型定价",
          "icon": "dollar-sign",
          "href": "https://xcompute.us/pricing"
        }
      ]
    },
    "tabs": [
      {
        "tab": "快速开始",
        "pages": [
          "file",
          "file-1",
          "quickstart",
          "hot-models-quickstart",
          "grok-video-guide"
        ]
      },
      {
        "tab": "新版接口",
        "icon": "plug",
        "groups": [
          {
            "group": "概览",
            "pages": [
              "new-api-reference"
            ]
          },
          {
            "group": "账户接口",
            "pages": [
              "api-reference/account/new-user-self",
              "api-reference/account/new-user-login",
              "api-reference/account/new-models"
            ]
          },
          {
            "group": "文本接口",
            "pages": [
              "api-reference/texts/general/new-chat-completions"
            ]
          },
          {
            "group": "图片接口",
            "pages": [
              "api-reference/images/new-images-generations"
            ]
          },
          {
            "group": "音频接口",
            "pages": [
              "api-reference/audios/new-audio-speech"
            ]
          },
          {
            "group": "视频接口",
            "pages": [
              "api-reference/videos/new-videos-generations",
              "api-reference/tasks/new-status"
            ]
          }
        ]
      },
      {
        "tab": "集成教程",
        "groups": [
          {
            "group": "基础环境",
            "pages": [
              "node-setup"
            ]
          },
          {
            "group": "AI 编程工具接入",
            "pages": [
              "claude-code",
              "codex",
              "opencode"
            ]
          },
          {
            "group": "AI 应用与工作流平台",
            "pages": [
              "openclaw",
              "comfyui",
              "dify",
              "n8n"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/APIMart_"
    }
  }
}
